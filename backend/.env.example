# ── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero-config for local dev):
DATABASE_URL=sqlite:///traces.db
# PostgreSQL/TimescaleDB (production):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/llm_observability

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=llm-observability-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9000

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=llm-observability-platform

# ── Model defaults ────────────────────────────────────────────────────────────
DEFAULT_LLM_MODEL=gpt-4o-mini
COST_ALERT_THRESHOLD_USD=0.05
LATENCY_WARNING_THRESHOLD_MS=2000.0
# Optional JSON override for model pricing:
# MODEL_PRICING_JSON={"my-custom-model":{"input_per_1k":0.001,"output_per_1k":0.002}}

# ── SLA targets ───────────────────────────────────────────────────────────────
SLA_AVAILABILITY_PCT=99.5
SLA_P95_LATENCY_MS=3000
SLA_P99_LATENCY_MS=6000
SLA_ERROR_RATE_MAX=0.02
SLA_HALLUCINATION_MAX=0.10
SLA_COST_BUDGET_DAILY=50.0

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
