{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "📊 Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests (24h)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "blue"}]}
        }
      },
      "targets": [{"refId": "A", "expr": "increase(http_requests_total[24h])"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (1m)",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.05, "color": "yellow"},
              {"value": 0.20, "color": "red"}
            ]
          }
        }
      },
      "targets": [{"refId": "A", "expr": "llm_error_rate{endpoint=\"/chat\"}"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Latency (ms)",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1000, "color": "yellow"},
              {"value": 3000, "color": "red"}
            ]
          }
        }
      },
      "targets": [{"refId": "A", "expr": "avg(p95_latency{operation=\"middleware_latency\"})"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Cost (USD)",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      },
      "targets": [{"refId": "A", "expr": "sum(total_cost_usd_sum)"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Hallucination Rate",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.10, "color": "yellow"},
              {"value": 0.30, "color": "red"}
            ]
          }
        }
      },
      "targets": [{"refId": "A", "expr": "llm_hallucination_rate"}]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Active Alert Rules",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"value": null, "color": "blue"}]}
        }
      },
      "targets": [{"refId": "A", "expr": "llm_alert_rules_total"}]
    },
    {
      "id": 10,
      "type": "row",
      "title": "⏱️ Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Latency Percentiles (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "fieldConfig": {
        "defaults": {"unit": "ms"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "p95"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}
        ]
      },
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m])) * 1000", "legendFormat": "p99"}
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "LLM vs Total Latency (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"refId": "A", "expr": "avg(p95_latency{operation=\"llm_latency\"})", "legendFormat": "LLM Latency"},
        {"refId": "B", "expr": "avg(p95_latency{operation=\"middleware_latency\"})", "legendFormat": "Total Latency"}
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "❌ Errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Error Rate by Endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "fieldConfig": {
        "defaults": {"unit": "percentunit"},
        "overrides": []
      },
      "targets": [
        {"refId": "A", "expr": "llm_error_rate", "legendFormat": "{{endpoint}}"}
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Request Rate (req/min)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "targets": [
        {"refId": "A", "expr": "rate(http_requests_total[1m]) * 60", "legendFormat": "Requests/min"}
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "💰 Cost & Tokens",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Cumulative Cost (USD)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}},
      "targets": [
        {"refId": "A", "expr": "sum(total_cost_usd_sum)", "legendFormat": "Total Cost"}
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Token Usage (total per 5m)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"refId": "A", "expr": "increase(llm_token_total[5m])", "legendFormat": "Tokens/5m"}
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "🧠 Hallucination & Quality",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 32},
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Faithfulness Score (avg)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              {"value": null, "color": "red"},
              {"value": 0.4, "color": "yellow"},
              {"value": 0.7, "color": "green"}
            ]
          }
        }
      },
      "targets": [
        {"refId": "A", "expr": "llm_faithfulness_score_avg", "legendFormat": "Avg Faithfulness"}
      ]
    },
    {
      "id": 42,
      "type": "piechart",
      "title": "Faithfulness Label Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
      "targets": [
        {"refId": "A", "expr": "llm_faithfulness_label_count", "legendFormat": "{{label}}"}
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "🚨 Alerts",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41},
      "collapsed": false
    },
    {
      "id": 51,
      "type": "table",
      "title": "Recent Alert Events",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 42},
      "targets": [
        {"refId": "A", "expr": "llm_alert_fired_total", "legendFormat": "{{rule_id}} {{severity}}"}
      ]
    },
    {
      "id": 60,
      "type": "row",
      "title": "🔬 A/B Testing",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "collapsed": false
    },
    {
      "id": 61,
      "type": "bargauge",
      "title": "A/B Test Win Rates",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 51},
      "targets": [
        {"refId": "A", "expr": "llm_ab_wins_total", "legendFormat": "{{variant}} ({{experiment}})"}
      ]
    },
    {
      "id": 62,
      "type": "timeseries",
      "title": "A/B Latency Comparison",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 51},
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "targets": [
        {"refId": "A", "expr": "llm_ab_control_latency_avg", "legendFormat": "Control"},
        {"refId": "B", "expr": "llm_ab_treatment_latency_avg", "legendFormat": "Treatment"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["llm", "observability", "hallucination", "cost", "latency", "alerts", "ab-testing"],
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "label": "Model",
        "query": "label_values(llm_request_total, model_name)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "endpoint",
        "type": "query",
        "label": "Endpoint",
        "query": "label_values(llm_error_rate, endpoint)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "LLM Observability Platform — Full Dashboard",
  "uid": "llm-observability-full",
  "version": 2
}
